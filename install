#!/usr/bin/env bash
# install — put canvas-cli on your PATH.
#
# Usage:
#   ./install            # symlink canvas-cli into ~/.local/bin
#
# canvas-cli bootstraps its own auth: on the exe.dev VM it talks to localhost
# (no token); off the VM it signs a token locally with the same SSH key
# `ssh exe.dev` uses — no new key is registered on your account — and caches it.
# See the "Authentication" section of the README.
set -euo pipefail

here() { cd "$(dirname "${BASH_SOURCE[0]}")" && pwd; }
ROOT="$(here)"
CLI_BIN="$ROOT/canvas-cli"

# On the VM, the canvas server answers on localhost:8000.
ON_VM=false
if curl -fsS -m 2 http://localhost:8000/api/canvas >/dev/null 2>&1; then
  ON_VM=true
fi

mkdir -p "$HOME/.local/bin"
ln -sf "$CLI_BIN" "$HOME/.local/bin/canvas-cli"
echo "✅ linked canvas-cli -> ~/.local/bin/canvas-cli" >&2

if $ON_VM; then
  echo "   On the VM: no token needed. Try: canvas-cli request 'Sketch the header'" >&2
else
  echo "   Off the VM: canvas-cli signs/caches an exe.dev token on first use" >&2
  echo "   (needs 'ssh exe.dev' to work). Try: canvas-cli request 'Sketch the header'" >&2
fi

case ":$PATH:" in
  *":$HOME/.local/bin:"*) ;;
  *) echo "   ⚠ ~/.local/bin isn't on your PATH; add it to run 'canvas-cli' directly." >&2 ;;
esac
