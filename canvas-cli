#!/usr/bin/env bash
# canvas-cli: request a hand-drawn canvas from a human, block until they send it back.
#
# Usage:
#   canvas-cli request "Sketch the blog header layout"   # creates + waits, downloads result
#   canvas-cli create  "prompt..."                        # just create, print id+url (no wait)
#   canvas-cli wait    <id> [out.png]                     # poll until done, download image
#   canvas-cli status  <id>
#
# Env:
#   CANVAS_BASE   base URL the agent polls.
#                   on the VM:  http://localhost:8000  (default, no token)
#                   off the VM: https://canvas.exe.xyz  (set CANVAS_TOKEN)
#   CANVAS_TOKEN  exe.dev VM bearer token, for off-VM agents (laptop CLI/desktop)
#                   ssh exe.dev ssh-key generate-api-key --vm=<vm> --label=canvas
#   CANVAS_PUBLIC public URL shown to the human  (default https://canvas.exe.xyz)
#   CANVAS_POLL   poll interval seconds (default 3)
set -euo pipefail

BASE="${CANVAS_BASE:-http://localhost:8000}"
PUBLIC="${CANVAS_PUBLIC:-https://canvas.exe.xyz}"
POLL="${CANVAS_POLL:-3}"

need() { command -v "$1" >/dev/null || { echo "need $1" >&2; exit 1; }; }
need curl; need jq

# cx: curl wrapper that injects the exe.dev VM bearer token when CANVAS_TOKEN is
# set. Required when the agent runs OFF the VM and reaches the canvas through
# https://canvas.exe.xyz; omitted (harmless) when hitting localhost on the VM.
cx() {
  if [ -n "${CANVAS_TOKEN:-}" ]; then
    curl -fsS -H "X-Exedev-Authorization: Bearer ${CANVAS_TOKEN}" "$@"
  else
    curl -fsS "$@"
  fi
}

create() {
  local prompt="$1"
  cx -X POST "$BASE/api/canvas" \
    -H 'Content-Type: application/json' \
    -d "$(jq -nc --arg p "$prompt" --arg by "${CANVAS_BY:-agent}" '{prompt:$p, by:$by}')"
}

status() { cx "$BASE/api/canvas/$1"; }

wait_done() {
  local id="$1" out="${2:-canvas-$1.png}"
  echo "⏳ waiting for human to draw (polling every ${POLL}s)…" >&2
  while :; do
    local st
    st=$(status "$id" | jq -r .status)
    if [ "$st" = "done" ]; then
      cx "$BASE/api/canvas/$id/image.png" -o "$out" || true
      cx "$BASE/api/canvas/$id/snapshot.json" -o "${out%.png}.snapshot.json" 2>/dev/null || true
      echo "✅ received. image -> $out" >&2
      status "$id" | jq '{id,status,text,has_image,has_snapshot}'
      return 0
    fi
    sleep "$POLL"
  done
}

cmd="${1:-}"; shift || true
case "$cmd" in
  create)
    create "${1:?prompt required}" | jq --arg pub "$PUBLIC" '. + {public_url: ($pub + .url)}'
    ;;
  request)
    resp=$(create "${1:?prompt required}")
    id=$(echo "$resp" | jq -r .id)
    echo "🎨 Open on your phone: $PUBLIC/c/$id" >&2
    wait_done "$id" "${2:-canvas-$id.png}"
    ;;
  wait)   wait_done "${1:?id required}" "${2:-}" ;;
  status) status "${1:?id required}" | jq . ;;
  *) echo "usage: canvas-cli {request|create|wait|status} ..." >&2; exit 1 ;;
esac
